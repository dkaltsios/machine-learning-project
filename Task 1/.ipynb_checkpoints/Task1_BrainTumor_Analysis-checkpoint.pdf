   "source": [
    "print(\"=\" * 70)\n",
    "print(\"STEP 2: INFORMATION GAIN — Catching Low Predictiveness\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "mi_scores = mutual_info_classif(X_step1, y, discrete_features=False, random_state=RANDOM_STATE)\n",
    "mi_df = pd.DataFrame({\n",
    "    'Feature': X_step1.columns,\n",
    "    'Information Gain': mi_scores\n",
    "}).sort_values('Information Gain', ascending=False).reset_index(drop=True)\n",
    "\n",
    "print('\\nMutual Information scores (higher = more predictive):')\n",
    "print(mi_df.to_string(index=False))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "bars = ax.barh(mi_df['Feature'], mi_df['Information Gain'],\n",
    "               color='#4CAF50', edgecolor='black', linewidth=0.5)\n",
    "ax.set_xlabel('Information Gain (Mutual Information with Class)')\n",
    "ax.set_title('Feature Importance — Information Gain', fontweight='bold')\n",
    "ax.invert_yaxis()\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "IG_THRESHOLD = 0.01\n",
    "low_ig_features = mi_df.loc[mi_df['Information Gain'] < IG_THRESHOLD, 'Feature'].tolist()\n",
    "if low_ig_features:\n",
    "    print(f'\\nFeatures with near-zero information gain (< {IG_THRESHOLD}): {low_ig_features}')\n",
    "    X_selected = X_step1.drop(columns=low_ig_features)\n",
    "    print(f'Dropped: {low_ig_features}')\n",
    "else:\n",
    "    print(f'\\nAll features have information gain ≥ {IG_THRESHOLD} — none dropped.')\n",
    "    X_selected = X_step1.copy()\n",
    "\n",
    "print(f'\\n{\"=\" * 50}')\n",
    "print(f'FINAL SELECTED FEATURES ({X_selected.shape[1]}):')\n",
    "print(f'  {list(X_selected.columns)}')\n",
    "print(f'{\"=\" * 50}')\n",
    "print(f'\\nJustification:')\n",
    "print(f'  Step 1: Removed {len(features_to_drop_corr)} features due to mathematical redundancy / collinearity (|r| > {CORR_THRESHOLD})')\n",
    "if low_ig_features:\n",
    "    print(f'  Step 2: Removed {len(low_ig_features)} feature(s) with near-zero information gain')\n",
    "else:\n",
    "    print(f'  Step 2: No features removed — all remaining features are predictive')"
   ]
  },
