    }
   ],
   "source": [
    "features_to_drop_corr = ['Variance', 'ASM']\n",
    "\n",
    "contrast_dissimilarity_corr = X['Contrast'].corr(X['Dissimilarity'])\n",
    "if abs(contrast_dissimilarity_corr) > CORR_THRESHOLD:\n",
    "    features_to_drop_corr.append('Dissimilarity')\n",
    "    print(f'Dropping Dissimilarity (r = {contrast_dissimilarity_corr:.4f} with Contrast > {CORR_THRESHOLD})')\n",
    "else:\n",
    "    print(f'Keeping Dissimilarity (r = {contrast_dissimilarity_corr:.4f} with Contrast ≤ {CORR_THRESHOLD})')\n",
    "\n",
    "X_step1 = X.drop(columns=features_to_drop_corr)\n",
    "\n",
    "print(f'\\nDropped (collinearity): {features_to_drop_corr}')\n",
    "print(f'  • Variance dropped — mathematically redundant with Standard Deviation (Var = Std²)')\n",
    "print(f'  • ASM dropped — mathematically redundant with Energy (Energy = √ASM)')\n",
    "if 'Dissimilarity' in features_to_drop_corr:\n",
    "    print(f'  • Dissimilarity dropped — highly correlated with Contrast (r > {CORR_THRESHOLD})')\n",
    "print(f'\\nRemaining features ({X_step1.shape[1]}): {list(X_step1.columns)}')\n",
    "\n",
    "corr_clean = X_step1.corr()\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "mask = np.triu(np.ones_like(corr_clean, dtype=bool))\n",
    "sns.heatmap(corr_clean, annot=True, fmt='.3f', cmap='RdBu_r', center=0,\n",
    "            mask=mask, square=True, linewidths=0.5, ax=ax,\n",
    "            vmin=-1, vmax=1, cbar_kws={'shrink': 0.8})\n",
    "ax.set_title('Correlation Heatmap — After Removing Redundant Features', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
