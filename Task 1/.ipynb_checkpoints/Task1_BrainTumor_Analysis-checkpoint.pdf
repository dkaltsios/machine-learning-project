   "source": [
    "---\n",
    "## Phase 3 — Classification\n",
    "\n",
    "Three classifiers trained with `Pipeline(StandardScaler → Classifier)` and\n",
    "`GridSearchCV` (5-fold stratified CV on the training set).\n",
    "\n",
    "- **Logistic Regression** — interpretable baseline\n",
    "- **Random Forest** — bagging ensemble with built-in feature importances\n",
    "- **XGBoost** — boosting ensemble for comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "35e2a801",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Training set: 3009 samples\n",
      "Test set:     753 samples\n",
      "\n",
      "Training class distribution:\n",
      "Class\n",
      "0    1663\n",
      "1    1346\n",
      "Name: count, dtype: int64\n",
      "\n",
      "Test class distribution:\n",
      "Class\n",
      "0    416\n",
      "1    337\n",
      "Name: count, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X_selected, y, test_size=0.2, random_state=RANDOM_STATE, stratify=y\n",
    ")\n",
    "print(f'Training set: {X_train.shape[0]} samples')\n",
    "print(f'Test set:     {X_test.shape[0]} samples')\n",
    "print(f'\\nTraining class distribution:\\n{y_train.value_counts()}')\n",
    "print(f'\\nTest class distribution:\\n{y_test.value_counts()}')\n",
    "\n",
    "feature_names = X_selected.columns.tolist()\n",
    "cv_strategy = StratifiedKFold(n_splits=5, shuffle=True, random_state=RANDOM_STATE)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "4a852e87",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Logistic Regression: 20 hyperparameter combinations × 5 folds = 100 fits\n",
      "Random Forest: 48 hyperparameter combinations × 5 folds = 240 fits\n",
      "XGBoost: 72 hyperparameter combinations × 5 folds = 360 fits\n"
     ]
    }
   ],
   "source": [
    "pipe_lr = Pipeline([\n",
    "    ('scaler', StandardScaler()),\n",
    "    ('clf', LogisticRegression(random_state=RANDOM_STATE, max_iter=1000))\n",
    "])\n",
    "param_grid_lr = {\n",
    "    'clf__C': [0.01, 0.1, 1, 10, 100],\n",
    "    'clf__penalty': ['l1', 'l2'],\n",
    "    'clf__solver': ['saga'],\n",
    "    'clf__class_weight': [None, 'balanced']\n",
    "}\n",
    "\n",
    "pipe_rf = Pipeline([\n",
    "    ('scaler', StandardScaler()),\n",
    "    ('clf', RandomForestClassifier(random_state=RANDOM_STATE))\n",
    "])\n",
    "param_grid_rf = {\n",
    "    'clf__n_estimators': [100, 300],\n",
    "    'clf__max_depth': [None, 10, 20],\n",
    "    'clf__min_samples_split': [2, 5],\n",
    "    'clf__max_features': ['sqrt', 'log2'],\n",
    "    'clf__class_weight': [None, 'balanced']\n",
    "}\n",
    "\n",
    "pipe_xgb = Pipeline([\n",
    "    ('scaler', StandardScaler()),\n",
    "    ('clf', xgb.XGBClassifier(random_state=RANDOM_STATE, eval_metric='logloss'))\n",
    "])\n",
    "scale_pos = (y_train == 0).sum() / (y_train == 1).sum()\n",
    "param_grid_xgb = {\n",
    "    'clf__n_estimators': [100, 300],\n",
    "    'clf__max_depth': [3, 5, 7],\n",
    "    'clf__learning_rate': [0.01, 0.1, 0.3],\n",
    "    'clf__subsample': [0.8, 1.0],\n",
    "    'clf__scale_pos_weight': [1, scale_pos]\n",
    "}\n",
    "\n",
    "models = {\n",
    "    'Logistic Regression': (pipe_lr, param_grid_lr),\n",
    "    'Random Forest': (pipe_rf, param_grid_rf),\n",
    "    'XGBoost': (pipe_xgb, param_grid_xgb)\n",
    "}\n",
    "\n",
    "for name, (_, grid) in models.items():\n",
    "    combos = 1\n",
    "    for vals in grid.values():\n",
    "        combos *= len(vals)\n",
    "    print(f'{name}: {combos} hyperparameter combinations × 5 folds = {combos * 5} fits')"
   ]
  },
