   "source": [
    "---\n",
    "## Phase 2 — Feature Selection (2-step process)\n",
    "\n",
    "### Step 1 — Correlation Matrix\n",
    "Compute pairwise correlations and drop one feature from any pair with |r| > 0.9.\n",
    "\n",
    "### Step 2 — Information Gain\n",
    "Use `mutual_info_classif` to measure each feature's predictive value for Class. Drop features with near-zero scores."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "ae9eb190",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "======================================================================\n",
      "STEP 1: CORRELATION MATRIX — Catching Collinearity\n",
      "======================================================================\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1440x1200 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Highly correlated pairs (|r| > 0.9):\n",
      "  Variance ↔ Standard Deviation: r = 0.9757\n",
      "  Entropy ↔ Energy: r = 0.9713\n",
      "  Entropy ↔ ASM: r = 0.9992\n",
      "  Energy ↔ ASM: r = 0.9616\n",
      "  Energy ↔ Homogeneity: r = 0.9160\n"
     ]
    }
   ],
   "source": [
    "print(\"=\" * 70)\n",
    "print(\"STEP 1: CORRELATION MATRIX — Catching Collinearity\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "corr_matrix = X.corr()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 10))\n",
    "mask = np.triu(np.ones_like(corr_matrix, dtype=bool))\n",
    "sns.heatmap(corr_matrix, annot=True, fmt='.3f', cmap='RdBu_r', center=0,\n",
    "            mask=mask, square=True, linewidths=0.5, ax=ax,\n",
    "            vmin=-1, vmax=1, cbar_kws={'shrink': 0.8})\n",
    "ax.set_title('Pearson Correlation Heatmap — All Features', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "CORR_THRESHOLD = 0.9\n",
    "print(f'\\nHighly correlated pairs (|r| > {CORR_THRESHOLD}):')\n",
    "high_corr_pairs = []\n",
    "for i in range(len(corr_matrix.columns)):\n",
    "    for j in range(i + 1, len(corr_matrix.columns)):\n",
    "        r = corr_matrix.iloc[i, j]\n",
    "        if abs(r) > CORR_THRESHOLD:\n",
    "            pair = (corr_matrix.columns[i], corr_matrix.columns[j], r)\n",
    "            high_corr_pairs.append(pair)\n",
    "            print(f'  {pair[0]} ↔ {pair[1]}: r = {pair[2]:.4f}')\n",
    "\n",
    "if not high_corr_pairs:\n",
    "    print('  None found.')"
   ]
  },
  {
   "cell_type": "code",
