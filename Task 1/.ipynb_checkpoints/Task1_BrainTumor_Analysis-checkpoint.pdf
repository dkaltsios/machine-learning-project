   "source": [
    "# --- XGBoost SHAP Values ---\n",
    "xgb_model = best_models['XGBoost'].best_estimator_\n",
    "X_test_scaled_xgb = xgb_model.named_steps['scaler'].transform(X_test)\n",
    "X_test_scaled_df = pd.DataFrame(X_test_scaled_xgb, columns=feature_names)\n",
    "\n",
    "explainer = shap.TreeExplainer(xgb_model.named_steps['clf'])\n",
    "shap_values = explainer.shap_values(X_test_scaled_df)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "shap.summary_plot(shap_values, X_test_scaled_df, show=False)\n",
    "plt.title('SHAP Summary — XGBoost Feature Impact', fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "shap.summary_plot(shap_values, X_test_scaled_df, plot_type='bar', show=False)\n",
    "plt.title('SHAP Global Feature Importance — XGBoost', fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# --- Consensus Top 2 ---\n",
    "lr_top2 = lr_importance['Feature'].head(2).tolist()\n",
    "shap_importance = pd.DataFrame({\n",
    "    'Feature': feature_names,\n",
    "    'Mean_|SHAP|': np.abs(shap_values).mean(axis=0)\n",
    "}).sort_values('Mean_|SHAP|', ascending=False)\n",
    "xgb_top2 = shap_importance['Feature'].head(2).tolist()\n",
    "\n",
    "print(f'\\nTop 2 by model:')\n",
    "print(f'  Logistic Regression (|coefficient|): {lr_top2}')\n",
    "print(f'  Random Forest (Gini importance):     {rf_top2}')\n",
    "print(f'  XGBoost (mean |SHAP|):               {xgb_top2}')\n",
    "\n",
    "all_top2 = lr_top2 + rf_top2 + xgb_top2\n",
    "feature_votes = Counter(all_top2)\n",
    "consensus_top2 = [f for f, _ in feature_votes.most_common(2)]\n",
    "print(f'\\n>>> CONSENSUS TOP 2: {consensus_top2}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "658e2872",
   "metadata": {},
   "source": [
    "---\n",
    "## Phase 4 — Clustering\n",
    "\n",
    "- Drop `Class` entirely and scale features with `StandardScaler`\n",
    "- Use Elbow Method + Silhouette Score to choose `k`\n",
    "- Run K-Means, then reintroduce `Class` and produce a contingency table\n",
    "- Compute homogeneity score as a formal purity metric"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "f358e772",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "======================================================================\n",
      "CLUSTERING ANALYSIS (K-MEANS)\n",
      "======================================================================\n",
      "\n",
      "Evaluating k values:\n",
      "  k=2: Inertia=26806.8, Silhouette=0.3429\n",
      "  k=3: Inertia=21244.8, Silhouette=0.3469\n",
      "  k=4: Inertia=17391.2, Silhouette=0.2918\n",
      "  k=5: Inertia=15446.1, Silhouette=0.2544\n",
      "  k=6: Inertia=14086.1, Silhouette=0.2646\n",
      "  k=7: Inertia=12885.4, Silhouette=0.2632\n",
      "  k=8: Inertia=11640.3, Silhouette=0.2600\n",
      "  k=9: Inertia=10712.5, Silhouette=0.2673\n",
      "  k=10: Inertia=10007.7, Silhouette=0.2552\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1680x600 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Optimal k by silhouette score: 3\n"
     ]
    }
   ],
   "source": [
    "print(\"=\" * 70)\n",
    "print(\"CLUSTERING ANALYSIS (K-MEANS)\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "scaler_cluster = StandardScaler()\n",
    "X_cluster = scaler_cluster.fit_transform(X_selected)\n",
    "\n",
    "k_range = range(2, 11)\n",
    "inertias = []\n",
    "silhouette_scores_list = []\n",
    "\n",
    "print('\\nEvaluating k values:')\n",
    "for k in k_range:\n",
    "    km = KMeans(n_clusters=k, n_init=10, random_state=RANDOM_STATE)\n",
    "    labels = km.fit_predict(X_cluster)\n",
    "    inertias.append(km.inertia_)\n",
    "    sil = silhouette_score(X_cluster, labels)\n",
    "    silhouette_scores_list.append(sil)\n",
    "    print(f'  k={k}: Inertia={km.inertia_:.1f}, Silhouette={sil:.4f}')\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "axes[0].plot(k_range, inertias, 'bo-', linewidth=2, markersize=8)\n",
    "axes[0].set_xlabel('Number of Clusters (k)')\n",
    "axes[0].set_ylabel('Inertia (Within-Cluster Sum of Squares)')\n",
    "axes[0].set_title('Elbow Method', fontweight='bold')\n",
    "axes[0].set_xticks(list(k_range))\n",
    "\n",
    "axes[1].plot(k_range, silhouette_scores_list, 'rs-', linewidth=2, markersize=8)\n",
    "axes[1].set_xlabel('Number of Clusters (k)')\n",
    "axes[1].set_ylabel('Mean Silhouette Score')\n",
    "axes[1].set_title('Silhouette Analysis', fontweight='bold')\n",
    "axes[1].set_xticks(list(k_range))\n",
    "\n",
    "best_k = list(k_range)[np.argmax(silhouette_scores_list)]\n",
    "axes[1].axvline(x=best_k, color='green', linestyle='--', linewidth=1.5,\n",
    "                label=f'Best k = {best_k}')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.suptitle('Determining Optimal Number of Clusters', fontsize=14, fontweight='bold', y=1.03)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "print(f'\\nOptimal k by silhouette score: {best_k}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "5c916ac3",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "=== Contingency Table: Actual Class vs K-Means Cluster ===\n",
      "Cluster          0     1   All\n",
      "Actual Class                  \n",
      "0             2043    36  2079\n",
      "1              129  1554  1683\n",
      "All           2172  1590  3762\n",
      "\n",
      "=== Cluster Quality Metrics ===\n",
      "Homogeneity Score:  0.7444  (1 = each cluster contains only one class)\n",
      "Cluster Purity:     0.9561  (fraction of dominant class per cluster)\n",
      "Silhouette Score:   0.3429  (higher = tighter, better-separated clusters)\n"
     ]
    }
   ],
   "source": [
    "km_final = KMeans(n_clusters=2, n_init=10, random_state=RANDOM_STATE)\n",
    "cluster_labels = km_final.fit_predict(X_cluster)\n",
    "\n",
    "contingency = pd.crosstab(\n",
    "    pd.Series(y.values, name='Actual Class'),\n",
    "    pd.Series(cluster_labels, name='Cluster'),\n",
    "    margins=True\n",
    ")\n",
    "print('=== Contingency Table: Actual Class vs K-Means Cluster ===')\n",
    "print(contingency)\n",
    "\n",
    "homo = homogeneity_score(y, cluster_labels)\n",
    "sil_final = silhouette_score(X_cluster, cluster_labels)\n",
    "\n",
    "contingency_no_margin = pd.crosstab(y, cluster_labels)\n",
    "purity = contingency_no_margin.max(axis=0).sum() / len(y)\n",
    "\n",
    "print(f'\\n=== Cluster Quality Metrics ===')\n",
    "print(f'Homogeneity Score:  {homo:.4f}  (1 = each cluster contains only one class)')\n",
    "print(f'Cluster Purity:     {purity:.4f}  (fraction of dominant class per cluster)')\n",
    "print(f'Silhouette Score:   {sil_final:.4f}  (higher = tighter, better-separated clusters)')"
   ]
  },
